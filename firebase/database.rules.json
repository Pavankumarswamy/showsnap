{
  "rules": {
    "users": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".indexOn": ["role"],
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin')"
      }
    },

    "theaters": {
      ".read": true,
      "$theaterId": {
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('theaters').child($theaterId).child('managerId').val() === auth.uid)"
      }
    },

    "screens": {
      ".indexOn": ["theaterId"],
      ".read": true,
      "$theaterId": {
        "$screenId": {
          ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('theaters').child($theaterId).child('managerId').val() === auth.uid)"
        }
      }
    },

    "movies": {
      ".read": true,
      "$movieId": {
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'theaterManager')"
      }
    },

    "shows": {
      ".indexOn": ["movieId", "screenId", "theaterId"],
      ".read": true,
      "$showId": {
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'theaterManager')",
        "seats": {
          "$seatId": {
            ".write": "auth != null"
          }
        }
      }
    },

    "bookings": {
      ".indexOn": ["uid", "showId", "theaterName"],
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'theaterManager' || root.child('users').child(auth.uid).child('role').val() === 'eventManager' || (query.orderByChild === 'uid' && query.equalTo === auth.uid))",
      "$bookingId": {
        ".read": "auth != null && (data.child('uid').val() === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'theaterManager' || root.child('users').child(auth.uid).child('role').val() === 'eventManager')",
        ".write": "auth != null && (data.child('uid').val() === auth.uid || !data.exists() && auth.uid != null || root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'theaterManager' || root.child('users').child(auth.uid).child('role').val() === 'eventManager')"
      }
    },

    "banners": {
      ".read": true,
      "$bannerId": {
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
      }
    },

    "offers": {
      ".read": true,
      "$offerId": {
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
      }
    },

    "coupons": {
      ".read": "auth != null",
      "$couponId": {
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
      }
    },

    "events": {
      ".read": true,
      "$eventId": {
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'eventManager')"
      }
    },

    "adRequests": {
      ".indexOn": ["uid"],
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      "$requestId": {
        ".read": "auth != null && (data.child('uid').val() === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && (!data.exists() || data.child('uid').val() === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin')"
      }
    },

    "notifications": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin')"
      }
    }
  }
}
